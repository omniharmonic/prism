# Production defaults: a deployed build targets the vault exposed via the
# Parachute Cloudflare tunnel (agent.omniharmonic.com → hub → vault). The token
# is still entered per-device on the connect screen. Dev builds fall back to
# http://localhost:1940 (see config.ts). Override via build-time env if needed.
VITE_VAULT_URL=https://agent.omniharmonic.com
VITE_VAULT_NAME=default
