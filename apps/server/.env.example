# Prism Server config (copy to .env; run with `node --env-file=.env`).

# HTTP
PORT=8787
# Public origin the app is served from (for cookies + magic-link URLs).
APP_ORIGIN=https://prism.omniharmonic.com

# Parachute vault (local to the home server — the token NEVER leaves this server)
PARACHUTE_URL=http://localhost:1940
PARACHUTE_VAULT=default
# A vault:default:write token minted via `parachute auth mint-token`.
PARACHUTE_TOKEN=

# Secrets (generate with: openssl rand -base64 48)
SESSION_SECRET=
CAPABILITY_SECRET=

# Identity
# The owner's email = the admin who has full access to the whole vault.
OWNER_EMAIL=benjamin@opencivics.co

# Magic-link email (Resend). Leave RESEND_API_KEY empty to disable email sign-in
# (capability links + owner login still work).
RESEND_API_KEY=
MAGIC_FROM=Prism <login@omniharmonic.com>

# SQLite store (sessions, users, grants)
DB_PATH=./prism-server.db
