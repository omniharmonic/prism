# Prism Server configuration — copy to `.env` and fill in.
# Easiest: run `npm run setup` (scripts/bootstrap.sh) to generate the secrets.
# NEVER commit `.env`. It holds the keys to the entire vault.

# ── Public origin ───────────────────────────────────────────────────────────
# The https URL the server is reached at (your Cloudflare tunnel hostname).
# Drives Secure cookies, HSTS, and the share-link domain. Use http://localhost:8787
# only for local-only testing (cookies won't be Secure).
APP_ORIGIN=https://prism.example.com
PORT=8787

# ── Parachute vault (the data) ──────────────────────────────────────────────
PARACHUTE_URL=http://localhost:1940
PARACHUTE_VAULT=default
# Hub-issued JWT with write scope. Mint with:
#   parachute auth mint-token --scope vault:default:write --expires-in 31536000
# This is the most sensitive secret here — full vault access. Server-only.
PARACHUTE_TOKEN=

# ── Secrets (generate strong random values — `openssl rand -base64 48`) ──────
# Signs session cookies. Rotating it logs everyone out.
SESSION_SECRET=
# Signs capability (share) links. Rotating it invalidates all outstanding links.
CAPABILITY_SECRET=
# Dedicated owner token for the desktop app's real-time + share connection.
# Put this SAME value in the desktop config (collab_token). Honored ONLY from
# localhost — useless if presented over the public tunnel. `openssl rand -base64 30`
COLLAB_TOKEN=

# ── Owner identity ──────────────────────────────────────────────────────────
# The one account with full vault access + the ability to issue invites and sign
# in via magic link. Everyone else is invite-only.
OWNER_EMAIL=you@example.com

# ── Email (magic links + invites) ───────────────────────────────────────────
# Resend API key. REQUIRED in production, or magic links/invites only log to the
# console (dev-only). The MAGIC_FROM sender must be on a Resend-verified domain.
RESEND_API_KEY=
MAGIC_FROM=Prism <login@example.com>

# ── Storage / paths ─────────────────────────────────────────────────────────
DB_PATH=./prism-server.db
WEB_ROOT=../web/dist
