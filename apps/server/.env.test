# Test-only environment for `npm test` (node --env-file=.env.test).
# These are NOT secrets — they are deterministic fixtures so the config layer,
# the SQLite store (in-memory), and the HMAC signing have stable inputs. The
# real .env (with the live PARACHUTE_TOKEN) is gitignored and never used here.
PARACHUTE_TOKEN=test-vault-token
SESSION_SECRET=test-session-secret-do-not-use-in-prod
CAPABILITY_SECRET=test-capability-secret-do-not-use-in-prod
OWNER_EMAIL=owner@test.local
APP_ORIGIN=http://localhost:8787
PARACHUTE_URL=http://vault.test
PARACHUTE_VAULT=default
# In-memory SQLite: each test *file* runs in its own process (node:test default),
# so each gets a fresh, isolated database. No file is written to disk.
DB_PATH=:memory:
PORT=8788

COLLAB_TOKEN=test-collab-token-xyz
