{
  "name": "@prism/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Prism Server — permission gateway + collab server in front of a Parachute vault.",
  "scripts": {
    "dev": "node --env-file=.env --watch --import tsx src/index.ts",
    "start": "node --env-file=.env --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --env-file=.env.test test/*.test.ts",
    "test:watch": "node --import tsx --test --watch --env-file=.env.test test/*.test.ts"
  },
  "dependencies": {
    "@hocuspocus/server": "^4.1.0",
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.8.1",
    "happy-dom": "^20.10.2",
    "hono": "^4.6.14",
    "marked": "^18.0.5",
    "resend": "^4.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3"
  }
}
