# .env.b.example — Hub B, the ISOLATED second Prism stack for the live federation
# convergence test (scripts/verify-two-hub.ts). Copy to .env.b and fill in, OR let
# scripts/two-hub-up.sh generate it for you (recommended — it mints the vault token
# and a stable PEER_SIGNING_KEY automatically).
#
#   cp .env.b.example .env.b   # then edit, or just run: bash scripts/two-hub-up.sh
#
# EVERY secret and the port MUST differ from .env (Hub A). Hub B points at a
# SEPARATE vault ("fed-b") so it never touches the live default vault.

# Public origin + port (distinct from Hub A's 8787).
APP_ORIGIN=http://localhost:8788
PORT=8788

# Parachute vault — a SECOND vault on the same hub (Parachute 0.7.x is hub-centric:
# one hub, many vaults by name). For stricter network isolation, run a second hub
# on its own data dir + port and set PARACHUTE_URL=http://localhost:2940.
PARACHUTE_URL=http://localhost:1940
PARACHUTE_VAULT=fed-b
# Mint with: parachute auth mint-token --scope vault:fed-b:write --expires-in 31536000
PARACHUTE_TOKEN=replace-with-fed-b-write-token

# Distinct secrets (openssl rand -base64 48). NEVER reuse Hub A's.
SESSION_SECRET=replace-with-unique-secret
CAPABILITY_SECRET=replace-with-unique-secret
# Owner token the harness presents as Bearer over localhost (collab_<...>).
COLLAB_TOKEN=replace-with-unique-collab-token

# A distinct owner identity for Hub B.
OWNER_EMAIL=ownerB@example.com

# Distinct Prism Server SQLite DB (the harness opens this to write the B-side
# mirror rows — spaces + federated_notes — since there is no /mirror endpoint yet).
DB_PATH=./prism-b.db

# Stable Ed25519 federation identity (PKCS8 DER, base64url). REQUIRED for a stable
# fingerprint across restarts. Generate with:
#   node --import tsx -e 'import("./src/auth/peer.ts").then(m=>console.log(m.generateKeyPairB64url().privateKeyB64url))'
PEER_SIGNING_KEY=replace-with-unique-pkcs8-der-base64url

# Master switch for the live federation transport/bridge.
FEDERATION_ENABLED=true
