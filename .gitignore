# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.png
.playwright-mcp/
.mcp.json

# Playwright e2e artifacts (apps/web)
test-results/
playwright-report/
.playwright/

# Private / sensitive — never commit
# .claude/ holds local working notes and (historically) a personal contacts
# export. Ignore the whole dir so nothing under it can be accidentally staged.
# Already-tracked planning docs under .claude/ remain tracked; new files do not.
.claude/
# Belt-and-suspenders: contact exports are never allowed anywhere in the tree.
*.abbu
*.abbu/

# Server runtime secrets / local SQLite
apps/server/.env
apps/server/*.sqlite
apps/server/*.sqlite-journal
apps/server/data/

# Never commit env files or their backups (only *.example templates) — secrets.
apps/server/.env*
!apps/server/.env*.example
!apps/server/.env.test
*.bak
*.bak.*
# Hub B federation sandbox (test stack)
apps/server/prism-b.db
apps/server/prism-b.log
